    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "speech-engine:register": "node --env-file=.env.local scripts/register-speech-engine.mjs",
    "speech-engine:serve": "node --env-file=.env.local server/speech-engine-server.mjs"
