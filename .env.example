# Google AI Studio — Gemini Native brain for property walkthrough (Gemini 3.5 Flash)
GEMINI_API_KEY=
GEMINI_BRAIN_MODEL=gemini-3.5-flash

# World Labs (3D — optional)
WORLD_LABS_API_KEY=

# OpenRouter (optional fallbacks)
OPENROUTER_API_KEY=

# ElevenLabs (Global Voice AI — ConvAI WebRTC + Scribe v2)
